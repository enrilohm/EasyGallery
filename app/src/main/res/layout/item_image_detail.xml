<?xml version="1.0" encoding="utf-8"?>
<com.example.easygallery.gallery.CropFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cropFrame"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.github.chrisbanes.photoview.PhotoView
        android:id="@+id/photoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.example.easygallery.faces.FaceOverlayView
        android:id="@+id/faceOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</com.example.easygallery.gallery.CropFrameLayout>
