{
    "name": "EasyGallery Android",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {}
    },
    // host networking lets ADB reach the phone over Wi-Fi (Android.fritz.box)
    "runArgs": ["--network=host"],
    "mounts": [
        // persist Gradle cache across container rebuilds
        "source=${localEnv:HOME}/.gradle,target=/root/.gradle,type=bind,consistency=cached",
        // persist adb pairing keys + debug signing keystore so rebuilds don't force re-pair / reinstall
        "source=${localEnv:HOME}/.android,target=/root/.android,type=bind,consistency=cached"
    ],
    // point Gradle at the SDK installed in the image
    "postCreateCommand": "npm install -g @anthropic-ai/claude-code && echo sdk.dir=${ANDROID_SDK_ROOT} > local.properties",
    "customizations": {
        "vscode": {
            "extensions": [
                "fwcd.kotlin"
            ]
        }
    }
}

